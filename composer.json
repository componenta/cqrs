{
    "name": "componenta/cqrs",
    "description": "CQRS (Command Query Responsibility Segregation) library for PHP 8.4+",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cqrs",
        "command",
        "query",
        "bus",
        "ddd"
    ],
    "require": {
        "php": ">=8.4",
        "componenta/arrayable": "^1.0",
        "componenta/config": "^1.0",
        "componenta/di": "^1.0",
        "componenta/iterator": "^1.0",
        "componenta/reflection": "^1.0",
        "psr/container": "^2.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\CQRS\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\CQRS\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\CQRS\\ConfigProvider"
            ]
        }
    }
}
